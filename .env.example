# PostgreSQL
POSTGRES_PASSWORD=vapt_secure_2025

# Backend
SECRET_KEY=change_me_to_a_long_random_string
ALLOWED_HOSTS=localhost,127.0.0.1

# Ollama (runs natively on host; Docker reaches it via host.docker.internal)
OLLAMA_URL=http://host.docker.internal:11434

# Scales every module's tool subprocess timeout + Celery soft/hard limit
# (see tasks/base_task.py's scaled_timeout()). 1.5 = default real-world
# headroom over the lab-tuned baselines; 1.0 reproduces the original timings.
SCAN_TIMEOUT_MULTIPLIER=1.5

# Concurrent-scan cap (resource-exhaustion guard, not a security boundary).
# Raise for deployments with more worker capacity.
MAX_CONCURRENT_SCANS=5
