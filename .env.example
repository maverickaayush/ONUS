# PostgreSQL
# Placeholder for local self-hosted use. Change it for any deployment reachable
# beyond localhost — the backend REFUSES to start with this value once ONUS_ENV
# is production or hosted auth is on (see backend/config.py validate_startup_security).
POSTGRES_PASSWORD=vapt_secure_2025

# Backend
# Generate a strong value:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be >=32 chars and not contain "change" once ONUS_ENV=production.
SECRET_KEY=change_me_to_a_long_random_string
ALLOWED_HOSTS=localhost,127.0.0.1

# Deployment posture: 'development' (default, self-hosted localhost — weak
# secrets only warn) or 'production' (weak SECRET_KEY / Postgres password become
# a hard boot failure). Leave as development for a plain `docker compose up`.
# ONUS_ENV=development

# Ollama (runs natively on host; Docker reaches it via host.docker.internal)
OLLAMA_URL=http://host.docker.internal:11434

# Scales every module's tool subprocess timeout + Celery soft/hard limit
# (see tasks/base_task.py's scaled_timeout()). 1.5 = default real-world
# headroom over the lab-tuned baselines; 1.0 reproduces the original timings.
SCAN_TIMEOUT_MULTIPLIER=1.5

# Concurrent-scan cap (resource-exhaustion / target-politeness guard, not a
# security boundary). Raise for deployments with more worker or Modal capacity.
MAX_CONCURRENT_SCANS=3

# ── Hosted auth + OAuth (ONLY needed when REQUIRE_AUTH=true) ──────────────────
# Self-hosted (the default) ignores everything below — docker compose up, enter
# target, tick authorization, scan. Leave these unset for self-hosted.
# REQUIRE_AUTH=false
# APP_URL is the frontend base URL; OAuth callbacks route back through its
# same-origin /api proxy. Register {APP_URL}/api/auth/google/callback and
# {APP_URL}/api/auth/github/callback with the providers.
# APP_URL=http://localhost:3002
# Google OAuth (Google Cloud Console -> Credentials -> OAuth client ID, Web):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GitHub OAuth (GitHub -> Settings -> Developer settings -> OAuth Apps):
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Optional email (OTP) for password signups; OAuth users skip OTP:
# EMAIL_BACKEND=smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=ONUS <no-reply@your-domain>

