# Python
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Environment variables
.env
.env.*
!.env.example

# Subfinder API keys (real, populated file) — template is committed instead
backend/subfinder-config/provider-config.yaml

# IDEs
.vscode/
.idea/

# Logs
*.log

# Database
*.db
*.sqlite3

# Build
dist/
build/

# Node
node_modules/

# Coverage
.coverage
htmlcov/

# OS files
.DS_Store
Thumbs.db

# graphify tool output
graphify-out/

# Vendored source for targets with no prebuilt image (built via compose, not pulled)
/nodegoat-src/
/dvwp-src/


# Next.js build output + build info (regenerated by `next build`/`next dev`)
.next/
*.tsbuildinfo

# Runtime scratch + scanner session data (not source)
/scratchpad/
# ZAP writes session data here at scan time; the DIRECTORY itself must exist
# and be writable by the non-root zap user before `docker compose up`, or the
# bind mount is created as root and ZAP dies with 'Permission denied'. Ignore
# the contents, keep the directory (via .gitkeep) so a fresh clone has it.
/zap-sessions/*
!/zap-sessions/.gitkeep

# Stray dev caches/config that must not ship
.vite/
.mcp.json

# Local-only hosted deployment setup notes (never commit)
docs/HOSTED_SETUP.md

# Auto-generated self-hosted SECRET_KEY (config.ensure_secret_key). Never commit.
.secret_key
